{
  "manifest_version": 3,
  "name": "Anirudhan LeetCode Sync",
  "version": "0.2.0",
  "description": "Save accepted LeetCode solutions into the local C-Anirudhan/LeetCode repository.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://127.0.0.1:8766/*",
    "http://localhost:8766/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page_bridge.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Anirudhan LeetCode Sync",
    "default_popup": "options.html"
  }
}
